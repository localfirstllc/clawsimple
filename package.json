{
  "name": "clawsimple",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "source:generate": "fumadocs-mdx",
    "db:generate": "tsx scripts/db/generate.ts",
    "db:generate:prod": "tsx scripts/db/generate.ts --prod",
    "db:migrate": "tsx scripts/db/migrate.ts",
    "db:migrate:prod": "tsx scripts/db/migrate.ts --prod",
    "db:check": "tsx scripts/db/check.ts",
    "db:check:prod": "tsx scripts/db/check.ts --prod",
    "db:studio": "drizzle-kit studio",
    "notify:dev": "wrangler dev --config wrangler.runner-notify.jsonc",
    "notify:deploy": "wrangler deploy --config wrangler.runner-notify.jsonc",
    "notify:tail": "wrangler tail --config wrangler.runner-notify.jsonc",
    "prepare": "simple-git-hooks",
    "test": "sh -c 'vitest run $(find src -type f \\( -name \"*.test.ts\" -o -name \"*.spec.ts\" \\))'",
    "test:ci": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:profile": "sh -c 'vitest run $(find \"src/app/[locale]/profile\" -type f \\( -name \"*.test.ts\" -o -name \"*.spec.ts\" \\))'",
    "test:deploy": "sh -c 'vitest run $(find src/app/api/deploy src/lib/deploy -type f \\( -name \"*.test.ts\" -o -name \"*.spec.ts\" \\))'"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored",
      "prettier --check"
    ],
    "*.spec.ts": [
      "sh -c 'if grep -nE \"page\\\\.evaluate|localStorage\\\\.setItem|sessionStorage\\\\.setItem|window\\\\.\\\\w+\\\\s*=\\\\s*true\" \"$@\" 2>/dev/null; then echo \"TEST CHEATING PATTERN DETECTED\" >&2; exit 1; fi' --"
    ]
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@aws-sdk/client-s3": "^3.992.0",
    "@aws-sdk/s3-request-presigner": "^3.992.0",
    "@better-auth/stripe": "^1.4.18",
    "@nanostores/react": "^1.0.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toast": "^1.2.15",
    "better-auth": "^1.4.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "form-data": "4.0.6",
    "framer-motion": "^12.29.2",
    "fumadocs-core": "^16.4.11",
    "fumadocs-mdx": "^14.2.6",
    "fumadocs-ui": "^16.4.11",
    "lucide-react": "^0.563.0",
    "mailgun.js": "13.2.0",
    "nanostores": "^1.1.0",
    "next": "16.1.6",
    "next-intl": "^4.7.0",
    "next-themes": "^0.4.6",
    "pg": "^8.18.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "stripe": "^20.3.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^17.2.4",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "happy-dom": "^20.10.6",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4",
    "telegram": "^2.26.22",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18",
    "wrangler": "^4.95.0"
  },
  "packageManager": "pnpm@10.23.0"
}
